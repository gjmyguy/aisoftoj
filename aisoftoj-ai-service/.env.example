QDRANT_COLLECTION=aisoftoj_doc_chunks
QDRANT_UPSERT_MAX_BYTES=25165824
QDRANT_UPSERT_MAX_POINTS=128

REDIS_URL=redis://localhost:6379/0

MINERU_URL=http://localhost:8000
MINERU_POLL_INTERVAL_SECONDS=2
MINERU_TASK_TIMEOUT_SECONDS=3600

INTERNAL_CALLBACK_URL=http://host.docker.internal:8080/internal/knowledge/callback
