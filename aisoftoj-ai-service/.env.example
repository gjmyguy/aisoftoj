INTERNAL_API_SECRET=change-me-with-a-different-long-random-secret

CHAT_BASE_URL=http://localhost:8001/v1
CHAT_API_KEY=67b2241e8b8cdd879cf50be110a40b9c8c9595009204ba65e32d21500ce5b49e
CHAT_MODEL=Qwen3.6-27B

EMBEDDING_BASE_URL=http://localhost:8002/v1
